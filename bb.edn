{:deps {}
 :paths ["src" "test"]
 :tasks
 {:override-builtin true
  run  {:doc "Start the agentic memory loop"
        :task (exec 'core/-main)}
  dream {:doc "Dream-Konsolidierung starten"
        :task (exec 'core/-main-dream)}
  memory {:doc "Langzeit-Gedächtnis anzeigen"
         :task (exec 'core/-main-memory)}
  install-plugin {:doc "Copilot CLI Plugin installieren (via 'copilot plugin install')"
                 :task (exec 'tasks.plugin/-main)}
  repl {:doc "Start a Babashka REPL"
        :task (exec 'clojure.main/main ["-r"])}
  db   {:doc "DB-Inhalt anzeigen: b db [N] [session=id]"
        :task (exec 'tasks.db/-main)}
  db-watch {:doc "DB live beobachten (wie tail -f): b db-watch [session=id]"
            :task (exec 'tasks.db/-main-watch)}
  hook-session-start {:doc "Lifecycle: sessionStart — Langzeit-Gedächtnis ausgeben"
                      :task (exec 'tasks.hooks/session-start)}
  hook-post-tool     {:doc "Lifecycle: postToolUse — Tool-Result speichern"
                      :task (exec 'tasks.hooks/post-tool)}
  hook-session-end   {:doc "Lifecycle: sessionEnd — Session markieren"
                      :task (exec 'tasks.hooks/session-end)}
  plugin-serve       {:doc "MCP plugin server starten (wird von Copilot CLI Plugin genutzt)"
                      :task (exec 'tasks.plugin-server/serve)}
  test {:doc "Run all tests"
        :requires ([babashka.fs :as fs]
                   [clojure.string :as str]
                   [clojure.test :as t])
        :task (do
                (doseq [file (sort (map str (fs/glob "." "test/*_test.clj")))]
                  (require
                   (symbol
                    (-> file
                        (str/replace (re-pattern "[/\\\\]") ".")
                        (str/replace (re-pattern "^test\\.") "")
                        (str/replace (re-pattern "\\.clj$") "")
                        (str/replace (re-pattern "_") "-")))))
                (let [{:keys [fail error]} (t/run-all-tests (re-pattern ".*-test$"))]
                  (when (pos? (+ fail error))
                    (throw (ex-info "Tests failed" {:fail fail :error error})))))}}}