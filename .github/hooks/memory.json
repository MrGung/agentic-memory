{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "bb scripts/memory_session_start.clj",
        "timeoutSec": 5
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "bb scripts/memory_post_tool.clj",
        "timeoutSec": 5
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "bb scripts/memory_session_end.clj",
        "timeoutSec": 10
      }
    ]
  }
}
