GITHUB_TOKEN=your_github_token_here
GITHUB_MODELS_MODEL=gpt-4o-mini
# Optional: Komma-separierte Liste erlaubter Shell-Programme (überschreibt Datei und Default)
SHELL_ALLOWED_COMMANDS=ls,find,cat,grep,echo,curl,git,gh,bb,pwd,env,which,date
# Optional: Pfad zu einer Datei mit erlaubten Shell-Programmen (ein Programm pro Zeile)
SHELL_ALLOWED_COMMANDS_FILE=.shell_allowed_commands

# Memory TTL (Time-to-Live) in Tagen pro Event-Typ
# MEMORY_TTL_USER_MESSAGE=30
# MEMORY_TTL_ASSISTANT_MESSAGE=30
# MEMORY_TTL_TOOL_RESULT=14
# MEMORY_TTL_TOOL_CALL=14
# MEMORY_TTL_SESSION_END=7
# MEMORY_TTL_SUMMARY=90
# MEMORY_TTL_LONG_TERM_MEMORY=   # leer lassen = kein Ablauf

# Automatisches Purge beim Start
# AUTO_PURGE=false
